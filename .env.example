# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>

# ── Database (pooled connection from Supabase → Transaction mode port 6543) ──
DATABASE_URL=postgresql+asyncpg://postgres.<your-project-ref>:<your-db-password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── LLM APIs ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-<your-anthropic-api-key>

# Embeddings — Voyage AI (free tier: 200M tokens, sign up at https://dash.voyageai.com/)
VOYAGE_API_KEY=pa-<your-voyage-api-key>

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Optional overrides (defaults shown) ──────────────────────────────────────
EXTRACTION_MODEL=claude-haiku-4-5-20251001
REASONING_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024
